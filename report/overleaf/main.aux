\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {IV-A}}Main 25 Class OOD Ablation}{3}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {IV-B}}Training Dynamics and Source to Target Decoupling}{3}{}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {III}{\ignorespaces PlantVillage to PlantDoc ablation, target metrics with TTA and TENT, $n{=}153$.}}{3}{}\protected@file@percent }
\newlabel{tab:ablation}{{III}{3}{}{table.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {IV}{\ignorespaces Source vs target dynamics for the full model. Source values come from the PlantVillage validation split. Target snapshots are raw evaluations during training (no TTA, no TENT). The final reported target accuracy of 52.29\% is with TTA and TENT applied to the best source F1 checkpoint.}}{3}{}\protected@file@percent }
\newlabel{tab:dynamics}{{IV}{3}{}{table.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {IV-C}}Per Class Target Performance}{3}{}\protected@file@percent }
\citation{Thapa2020}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Training and validation curves for the four ablations across 15 epochs. Top row is training loss, middle row is source validation accuracy, bottom row is target snapshots taken every three epochs. The full, backbone only, and no fusion variants all reach over 99.7\% source accuracy, but the target trajectory is flat or even declines after epoch 9, which means the source best checkpoint is not necessarily the target best checkpoint. The PC only variant never reaches a competitive source level, and its target collapse confirms that the structural stream alone is not enough.}}{4}{}\protected@file@percent }
\newlabel{fig:traininggrid}{{2}{4}{}{figure.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {IV-D}}What the Recipe Actually Buys}{4}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {IV-E}}Strict Apple Overlap Benchmark}{4}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Source (PlantVillage) and target (PlantDoc) confusion matrices for the full model with TTA and TENT. The source matrix is nearly diagonal. The target matrix is diffuse across many classes, which is consistent with domain shift rather than underfitting.}}{4}{}\protected@file@percent }
\newlabel{fig:confusion}{{3}{4}{}{figure.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {V}{\ignorespaces Per class target metrics for the full model with TTA and TENT. Classes with zero support are excluded. Names are abbreviated for space.}}{5}{}\protected@file@percent }
\newlabel{tab:perclass}{{V}{5}{}{table.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Qualitative diagnostic for the full model. From left to right: input leaf, PC magnitude, phase symmetry, and the cross attention overlay. Attention concentrates on lesion edges and vein structure, so the model does respond to biologically meaningful features even though the OOD accuracy is modest.}}{5}{}\protected@file@percent }
\newlabel{fig:qualitative}{{4}{5}{}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Illumination invariance check. The CLAHE stream reduces within class lighting variance before classification, which is one of the larger nuisance factors when going from PlantVillage to PlantDoc.}}{5}{}\protected@file@percent }
\newlabel{fig:illumination}{{5}{5}{}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces HSV leaf mask sanity check. The green overlay is the foreground produced by the saturation threshold. The mask separates the leaf from background reasonably well, which is what we need before extracting PC features so they are computed on leaf pixels rather than background.}}{5}{}\protected@file@percent }
\newlabel{fig:leafmask}{{6}{5}{}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Apple overlap baseline. Source accuracy is 99.96\% on both targets. PP2021 macro F1 (0.6813) is much lower than PlantDoc apple overlap macro F1 (0.8632). The PlantDoc result is on only 29 samples and should be treated as anecdotal.}}{5}{}\protected@file@percent }
\newlabel{fig:appleoverlap}{{7}{5}{}{figure.7}{}}
\@writefile{toc}{\contentsline {section}{\numberline {V}Discussion}{5}{}\protected@file@percent }
\newlabel{sec:discussion}{{V}{5}{}{section.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {VI}{\ignorespaces PP2021 apple overlap interventions, $n{=}11{,}310$. Fix A applies prior calibration to logits at inference. Fix B re weights the source sampler at training time.}}{6}{}\protected@file@percent }
\newlabel{tab:fixes}{{VI}{6}{}{table.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Macro accuracy and F1 on PP2021 across all interventions. Fix B with softer rebalancing has the best macro F1. Fix A interventions are either net harmful or roughly flat, which says calibration alone is not enough.}}{6}{}\protected@file@percent }
\newlabel{fig:ppmacro}{{8}{6}{}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Per class F1 on PP2021 under each intervention. Full rebalancing pushes scab F1 up to 0.7085 but drops cedar apple rust to 0.5551. The softer setting brings rust back to 0.5820 while keeping scab and healthy gains, which is why it has the best macro F1.}}{6}{}\protected@file@percent }
\newlabel{fig:ppclassf1}{{9}{6}{}{figure.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {VII}{\ignorespaces Per class PP2021 metrics for the best variant (Fix B softer rebalance, $\text  {power}=0.5$).}}{6}{}\protected@file@percent }
\newlabel{tab:perclass_apple}{{VII}{6}{}{table.7}{}}
